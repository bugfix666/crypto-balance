{
    "$schema": "https://getcomposer.org/schema.json",
    "name": "appsinvest/crypto-balance",
    "type": "project",
    "description": "System for managing user's cryptocurrency balances.",
    "keywords": ["laravel", "framework"],
    "license": "GPL-3.0-only",
    "require": {
        "php": "^8.4",
        "ext-bcmath": "*",
        "ext-curl": "*",
        "ext-http": "*",
        "ext-redis": "*",
        "ext-zlib": "*",
        "bugfix666/crypto-balance-wallet": "^1.0",
        "laravel/framework": "^12.0",
        "laravel/horizon": "^5",
        "laravel/tinker": "^2.10.1",
        "softinvest/http-response": "^1.0"
    },
    "require-dev": {
        "barryvdh/laravel-ide-helper": "^3",
        "beyondcode/laravel-self-diagnosis": "^3.0",
        "darkaonline/l5-swagger": "^8.6",
        "fakerphp/faker": "^1.23",
        "larastan/larastan": "^3",
        "laravel/pail": "^1.2.2",
        "laravel/pint": "^1.13",
        "laravel/sail": "^1.41",
        "mockery/mockery": "^1.6",
        "nunomaduro/collision": "^8.6",
        "nunomaduro/phpinsights": "^2.11",
        "phpstan/phpstan": "^2",
        "phpunit/phpunit": "^11.5.3",
        "slevomat/coding-standard": "~8.0",
        "squizlabs/php_codesniffer": "^3.10",
        "vimeo/psalm": "^6.12"
    },
    "autoload": {
        "psr-4": {
            "App\\": "app/",
            "Database\\Factories\\": "database/factories/",
            "Database\\Seeders\\": "database/seeders/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "scripts": {
        "post-autoload-dump": [
            "Illuminate\\Foundation\\ComposerScripts::postAutoloadDump",
            "@php artisan package:discover --ansi"
        ],
        "post-update-cmd": [
            "@php artisan vendor:publish --tag=laravel-assets --ansi --force"
        ],
        "post-root-package-install": [
            "@php -r \"file_exists('.env') || copy('.env.example', '.env');\""
        ],
        "post-create-project-cmd": [
            "@php artisan key:generate --ansi",
            "@php -r \"file_exists('database/database.sqlite') || touch('database/database.sqlite');\"",
            "@php artisan migrate --graceful --ansi"
        ],
        "cs-check": "phpcs . --standard=ruleset.xml",
        "cs-fix": "phpcbf app --standard=ruleset.xml",
        "phpstan": "phpstan analyse --configuration=phpstan.neon --memory-limit=512M --no-progress --error-format=table --no-interaction --ansi",
        "lint": "vendor/bin/parallel-lint --exclude .git --exclude vendor .",
        "psalm": "vendor/bin/psalm --no-cache",
        "tests": "vendor/bin/phpunit",
        "swagger": "@php artisan l5-swagger:generate",
        "dev": [
            "Composer\\Config::disableProcessTimeout",
            "npx concurrently -c \"#93c5fd,#c4b5fd,#fb7185,#fdba74\" \"php artisan serve\" \"php artisan queue:listen --tries=1\" \"php artisan pail --timeout=0\" \"npm run dev\" --names=server,queue,logs,vite"
        ],
        "test": [
            "@php artisan config:clear --ansi",
            "@php artisan test"
        ]
    },
    "extra": {
        "laravel": {
            "dont-discover": []
        }
    },
    "config": {
        "optimize-autoloader": true,
        "preferred-install": "dist",
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true,
            "php-http/discovery": true,
            "dealerdirect/phpcodesniffer-composer-installer": true
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
